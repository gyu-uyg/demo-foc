{
    "cortex-debug.openocdPath": "/opt/homebrew/bin/openocd",
    "cortex-debug.armToolchainPath": "/opt/arm-gnu-toolchain-14.3.rel1-darwin-arm64-arm-none-eabi/bin",

    "C_Cpp.errorSquiggles": "disabled",

    "cmake.useCMakePresets": "never",
    "cmake.generator": "Ninja",
    "cmake.buildDirectory": "${workspaceFolder}/build/${buildType}",
    "cmake.configureOnOpen": false,

    "cmake.configureSettings": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_MAKE_PROGRAM": "/opt/homebrew/bin/ninja",
        "CMAKE_SYSTEM_NAME": "Generic",
        "CMAKE_SYSTEM_PROCESSOR": "arm",
        "CMAKE_TRY_COMPILE_TARGET_TYPE": "STATIC_LIBRARY",

        "CMAKE_C_COMPILER": "/opt/arm-gnu-toolchain-14.3.rel1-darwin-arm64-arm-none-eabi/bin/arm-none-eabi-gcc",
        "CMAKE_CXX_COMPILER": "/opt/arm-gnu-toolchain-14.3.rel1-darwin-arm64-arm-none-eabi/bin/arm-none-eabi-g++",
        "CMAKE_ASM_COMPILER": "/opt/arm-gnu-toolchain-14.3.rel1-darwin-arm64-arm-none-eabi/bin/arm-none-eabi-gcc",

        "CMAKE_C_FLAGS": "-mcpu=cortex-m3 -mthumb -Os -ffunction-sections -fdata-sections",
        "CMAKE_CXX_FLAGS": "-mcpu=cortex-m3 -mthumb -Os -ffunction-sections -fdata-sections",
        "CMAKE_ASM_FLAGS": "-mcpu=cortex-m3 -mthumb",
        "CMAKE_EXE_LINKER_FLAGS": "-mcpu=cortex-m3 -mthumb -T ${workspaceFolder}/STM32F103XX_FLASH.ld --specs=nano.specs --specs=nosys.specs -Wl,--gc-sections -Wl,--print-memory-usage"
    },

    "python.testing.unittestArgs": [
        "-v",
        "-s",
        ".",
        "-p",
        "*test.py"
    ],
    "python.testing.pytestEnabled": false,
    "python.testing.unittestEnabled": true
}